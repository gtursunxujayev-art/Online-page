# Frontend Environment Variables
# Optional backend URL for API requests. Keep empty for same-domain /api paths.
VITE_API_URL=

# Backend Environment Variables (Vercel)
AMOCRM_SUBDOMAIN=
AMOCRM_ACCESS_TOKEN=
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=

# Optional: protect content update endpoint with a bearer token
ADMIN_TOKEN=

# Optional custom field IDs for tracking mapping (if set, used instead of field_code)
AMOCRM_FIELD_ID_UTM_SOURCE=
AMOCRM_FIELD_ID_UTM_MEDIUM=
AMOCRM_FIELD_ID_UTM_CAMPAIGN=
AMOCRM_FIELD_ID_UTM_CONTENT=
AMOCRM_FIELD_ID_UTM_TERM=
AMOCRM_FIELD_ID_UTM_REFERRER=
AMOCRM_FIELD_ID_REFERRER=
AMOCRM_FIELD_ID_FBCLID=
AMOCRM_FIELD_ID_GCLID=
